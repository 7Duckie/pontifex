# Composer
/vendor/
composer.phar

# Node (wp-env tooling; package.json and package-lock.json are committed)
/node_modules/

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# OS noise
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Test artefacts
/.phpunit.cache/
.phpunit.result.cache
/coverage/
/build/

# Infection (mutation testing) artefacts — generated locally, never committed
/infection.log
/.infection/

# Pre-commit
/.pre-commit-cache/

# PHPStan
/.phpstan-cache/

# Local dev databases / archives
*.sql
*.wpmig
*.wpmig.snapshot
# The one deliberate exception: the committed conformance golden archive
# (Appendix A of docs/archive-format.md) — a tiny canonical fixture, never a
# real backup.
!tests/Fixtures/*.wpmig

# Logs
*.log

# Environment files
.env
.env.local

# wp-env per-checkout PHP/version override (created locally and in CI; never
# committed — the tracked .wp-env.json / .wp-env.tests.json are the shared baseline)
/.wp-env.override.json
/.wp-env.tests.override.json

# Local working state (Claude session context)
STATE.md
AUDIT-FINDINGS.md
