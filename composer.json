{
    "name": "7duckie/pontifex",
    "description": "A free, open-source WordPress migration plugin with a documented archive format and first-class rollback.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "migration", "backup", "rollback"],
    "homepage": "https://github.com/7Duckie/pontifex",
    "require": {
        "php": ">=8.1",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/wp-cli-stubs": "^2.10",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Pontifex\\": "src/",
            "Pontifex\\Restore\\": "src/Restore/",
            "Pontifex\\WordPress\\": "src/WordPress/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pontifex\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
      "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
      "check": [
          "@lint",
          "@analyse",
          "@test",
          "@composer audit"
      ],
      "dev:setup": [
      "@php -r \"echo 'Installing pre-commit hooks...' . PHP_EOL;\"",
        "python3 -m pip install pre-commit",
      "pre-commit install --hook-type pre-commit --hook-type pre-push",
      "@php -r \"echo 'Done. Run composer check before committing.' . PHP_EOL;\""
      ],
      "lint": "phpcs --standard=phpcs.xml.dist",
      "lint:fix": "phpcbf --standard=phpcs.xml.dist",
      "test": "phpunit",
        "test:integration": "phpunit --testsuite=integration",
      "test:unit": "phpunit --testsuite=unit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
