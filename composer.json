{
  "autoload": {
    "psr-4": {
      "Pontifex\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Pontifex\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": true
    },
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true
  },
  "description": "A free, open-source WordPress migration and backup plugin with a documented archive format.",
  "homepage": "https://github.com/7Duckie/pontifex",
  "keywords": [
    "wordpress",
    "migration",
    "backup",
    "rollback"
  ],
  "license": "GPL-2.0-or-later",
  "minimum-stability": "stable",
  "name": "7duckie/pontifex",
  "prefer-stable": true,
  "require": {
    "php": ">=8.2",
    "composer/installers": "^2.2",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "brain/monkey": "^2.7",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "infection/infection": "^0.32.6",
    "mockery/mockery": "^1.6",
    "php-stubs/wp-cli-stubs": "^2.10",
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^11.0",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.1",
    "wp-phpunit/wp-phpunit": "^7.0",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "scripts": {
    "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
    "check": [
      "@lint",
      "@analyse",
      "@test",
      "@composer audit --abandoned=report"
    ],
    "dev:setup": [
      "@php -r \"echo 'Installing pre-commit hooks...' . PHP_EOL;\"",
      "python3 -m pip install pre-commit",
      "pre-commit install --hook-type pre-commit --hook-type pre-push --hook-type commit-msg",
      "@php -r \"echo 'Done. Run composer check before committing.' . PHP_EOL;\""
    ],
    "infection": "@php -d memory_limit=-1 vendor/bin/infection --threads=max",
    "lint": "phpcs --standard=phpcs.xml.dist",
    "lint:fix": "phpcbf --standard=phpcs.xml.dist",
    "test": "phpunit",
    "test:integration": "phpunit -c phpunit-integration.xml.dist",
    "test:unit": "phpunit --testsuite=unit"
  },
  "suggest": {
    "ext-openssl": "AES-256-GCM for archive encryption on hosts whose CPU lacks the hardware AES support libsodium needs; the software fallback cipher.",
    "ext-sodium": "Argon2id key derivation and AES-256-GCM for archive encryption; required to produce or read an encrypted archive.",
    "ext-zstd": "Faster, denser compression than gzip for archive entries (codec 0x0002); Pontifex falls back to gzip when it is absent."
  },
  "type": "wordpress-plugin"
}
