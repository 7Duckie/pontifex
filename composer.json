{
    "name": "7duckie/pontifex",
    "description": "A free, open-source WordPress migration plugin with a documented archive format and first-class rollback.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "migration", "backup", "rollback"],
    "homepage": "https://github.com/7Duckie/pontifex",
    "require": {
        "php": ">=8.1",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/wp-cli-stubs": "^2.10",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Pontifex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pontifex\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "check": [
            "@lint",
            "@analyse",
            "@test",
            "@composer audit"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
