parameters:
    level: 6
    phpVersion: 80200

    paths:
        - pontifex.php
        - src

    excludePaths:
        - vendor/*
        - tests/fixtures/*

    bootstrapFiles:
        - vendor/szepeviktor/phpstan-wordpress/bootstrap.php

    # WP-CLI symbols (WP_CLI, WP_CLI\Formatter, etc.) live in a separate
    # stubs package. phpstan-wordpress's bootstrap only covers core WP
    # functions and classes; we add the WP-CLI stubs explicitly here so
    # PHPStan can resolve calls like WP_CLI::add_command() and the
    # WP_CLI\Formatter constructor. We also scan tiny local stubs for the
    # php-cli-tools cli\ symbols Pontifex uses — cli\progress\Bar (returned
    # by make_progress_bar) and cli\prompt (the hidden passphrase prompt) —
    # which the main wp-cli-stubs file does not include.
    scanFiles:
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        - stubs/cli-progress-bar.stub
        - stubs/cli-prompt.stub

    # Treat these as known global constants defined by our bootstrap.
    # PHPStan analyses src/ files in isolation and wouldn't otherwise
    # know these exist.
    dynamicConstantNames:
        - PONTIFEX_PLUGIN_FILE
        - PONTIFEX_PLUGIN_DIR
        - PONTIFEX_PLUGIN_URL
        - PONTIFEX_MINIMUM_PHP_VERSION
        - PONTIFEX_MINIMUM_WP_VERSION

includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
